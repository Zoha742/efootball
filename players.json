const fs = require('fs');
const { MongoClient } = require('mongodb');

// MongoDB connection URI (নিজের URI বসাও)
const uri = "mongodb://localhost:27017";
const client = new MongoClient(uri);

async function updatePlayerJson() {
  try {
    await client.connect();
    const db = client.db("efootballDB");

    // Collections থেকে ডেটা ফেচ করো
    const players = await db.collection("players").find({}).toArray();
    const legends = await db.collection("legends").find({}).toArray();
    const managers = await db.collection("managers").find({}).toArray();
    const events = await db.collection("events").find({}).toArray();

    // JSON structure বানাও
    const data = {
      players,
      legends,
      managers,
      events
    };

    // player.json এ লিখে দাও
    fs.writeFileSync("player.json", JSON.stringify(data, null, 2));
    console.log("✅ player.json updated successfully!");
  } catch (err) {
    console.error("❌ Error updating player.json:", err);
  } finally {
    await client.close();
  }
}

updatePlayerJson();
